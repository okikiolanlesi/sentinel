# =============================================
# SentinelAI Frontend — Environment Variables
# =============================================
# 1. Copy this file: cp .env.example .env
# 2. For local dev, leave VITE_API_URL pointing at the local backend.
# 3. For deployed builds (Vercel/Netlify/etc), set VITE_API_URL to your
#    deployed backend URL e.g. https://sentinelai-backend.up.railway.app

VITE_API_URL=http://localhost:8000
