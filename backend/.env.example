# =============================================
# SentinelAI Backend — Environment Variables
# =============================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in AZURE_API_KEY with the key from your Microsoft AI Foundry deployment
# 3. (optional) Generate a strong SECRET_KEY:
#       python -c "import secrets; print(secrets.token_urlsafe(32))"

# Azure OpenAI / Microsoft AI Foundry
AZURE_ENDPOINT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_API_VERSION=xxxxxxxxxxxxx
AZURE_CHAT_MODEL=xxxxxxxxxxxx

AZURE_ENDPOINT_SWEDEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_API_KEY_SWEDEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT
SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxx
ACCESS_TOKEN_EXPIRE_MINUTES=xxxx

# Database
DATABASE_URL=xxxxxxxxxxxxxxxxxx
# Environment
ENVIRONMENT=xxxxxxxxxx
